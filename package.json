{
    "name": "scoreboard",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "dotenv": "^17.2.2",
            "zod": "^4.1.13",
            "@types/bun": "^1.3.4",
            "hono": "^4.8.2",
            "@trpc/server": "^11.7.2",
            "better-auth": "1.5.2",
            "lucide-react": "^0.546.0",
            "next-themes": "^0.4.6",
            "react": "^19.2.3",
            "react-dom": "^19.2.3",
            "sonner": "^2.0.5",
            "@libsql/client": "0.15.15",
            "libsql": "0.5.22",
            "@trpc/client": "^11.7.2",
            "@types/react": "^19.2.10",
            "@types/react-dom": "^19.2.3",
            "tailwindcss": "^4.1.18"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "check-types": "turbo check-types",
        "dev:web": "turbo -F web dev",
        "dev:server": "turbo -F server dev",
        "db:push": "turbo -F @scoreboard/db db:push",
        "db:studio": "turbo -F @scoreboard/db db:studio",
        "db:generate": "turbo -F @scoreboard/db db:generate",
        "db:migrate": "turbo -F @scoreboard/db db:migrate",
        "db:local": "turbo -F @scoreboard/db db:local",
        "check": "biome check --write ."
    },
    "dependencies": {
        "@scoreboard/env": "workspace:*",
        "dotenv": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@scoreboard/config": "workspace:*",
        "@types/bun": "catalog:",
        "turbo": "^2.8.12",
        "typescript": "^5"
    },
    "packageManager": "bun@1.3.11"
}
